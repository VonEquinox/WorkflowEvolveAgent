{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-evolution-agent.local/schemas/artifact.schema.json",
  "title": "WEA Artifact v1",
  "type": "object",
  "properties": {
    "schema": {
      "const": "wea.artifact/v1"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "kind": {
      "const": "Artifact"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "media_type": {
      "type": "string",
      "pattern": "^[A-Za-z0-9!#$&^_.+-]+/[A-Za-z0-9!#$&^_.+-]+(?:;.*)?$"
    },
    "logical_schema": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "storage_ref": {
      "type": "string",
      "pattern": "^cas-(?:private|shared)://sha256/[0-9a-f]{64}$"
    },
    "producer": {
      "$ref": "#/$defs/artifactProducer"
    },
    "source_snapshot_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "dependencies": {
      "$ref": "#/$defs/artifactDependencies"
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      },
      "uniqueItems": true
    },
    "coverage": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "security": {
      "$ref": "#/$defs/artifactSecurity"
    },
    "reuse_policy": {
      "$ref": "#/$defs/reusePolicy"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "critical_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object"
    }
  },
  "required": [
    "schema",
    "schema_version",
    "kind",
    "artifact_id",
    "media_type",
    "logical_schema",
    "size_bytes",
    "storage_ref",
    "producer",
    "source_snapshot_digest",
    "dependencies",
    "claims",
    "coverage",
    "limitations",
    "security",
    "reuse_policy",
    "created_at",
    "expires_at"
  ],
  "additionalProperties": false,
  "$defs": {
    "artifactProducer": {
      "type": "object",
      "properties": {
        "attempt_id": {
          "type": "string",
          "format": "uuid"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "executor_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "instance_ref": {
          "$ref": "#/$defs/workflowInstanceRef"
        },
        "effects": {
          "type": "object",
          "properties": {
            "read_scope": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "write_scope": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "write_semantics": {
              "enum": [
                "none",
                "content_addressed",
                "idempotent",
                "non_idempotent"
              ]
            },
            "network_access": {
              "enum": [
                "deny",
                "pinned",
                "live"
              ]
            },
            "external_side_effects": {
              "enum": [
                "none",
                "idempotent",
                "non_idempotent"
              ]
            },
            "determinism": {
              "enum": [
                "deterministic",
                "seeded",
                "nondeterministic"
              ]
            },
            "replay_policy": {
              "enum": [
                "safe",
                "verify",
                "forbidden"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "read_scope",
            "write_scope",
            "write_semantics",
            "network_access",
            "external_side_effects",
            "determinism",
            "replay_policy"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "attempt_id",
        "trace_id",
        "executor_digest",
        "instance_ref",
        "effects"
      ]
    },
    "artifactDependencies": {
      "type": "object",
      "properties": {
        "root_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "negative_dependency_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "completeness": {
          "enum": [
            "complete",
            "conservative",
            "incomplete"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "root_digest",
        "negative_dependency_root",
        "completeness"
      ]
    },
    "claim": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "evidence_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "evidence_digest"
      ]
    },
    "artifactSecurity": {
      "type": "object",
      "properties": {
        "classification": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "taints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "allowed_consumers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowed_purposes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "classification",
        "taints",
        "allowed_consumers",
        "allowed_purposes"
      ]
    },
    "reusePolicy": {
      "type": "object",
      "properties": {
        "publish_scope": {
          "enum": [
            "local",
            "project",
            "shared"
          ]
        },
        "allowed_cache_modes": {
          "type": "array",
          "items": {
            "enum": [
              "EXACT",
              "SEMANTIC",
              "ADAPT"
            ]
          },
          "maxItems": 3,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "publish_scope",
        "allowed_cache_modes"
      ]
    },
    "templateReleaseRef": {
      "type": "object",
      "properties": {
        "logical_id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_.-]*/[A-Za-z][A-Za-z0-9_.-]*$"
        },
        "template_version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "release_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "spec_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "logical_id",
        "template_version",
        "release_digest",
        "spec_digest"
      ]
    },
    "workflowInstanceRef": {
      "type": "object",
      "properties": {
        "instance_id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "template_release": {
          "$ref": "#/$defs/templateReleaseRef"
        },
        "instance_spec_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "instance_id",
        "template_release",
        "instance_spec_digest"
      ]
    }
  }
}
