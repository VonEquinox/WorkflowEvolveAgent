{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-evolution-agent.local/schemas/reuse-certificate.schema.json",
  "title": "WEA ReuseCertificate v1",
  "type": "object",
  "properties": {
    "schema": {
      "const": "wea.reuse-certificate/v1"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "kind": {
      "const": "ReuseCertificate"
    },
    "certificate_id": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "certificate_version": {
      "const": "1.0.0"
    },
    "subject": {
      "$ref": "#/$defs/certSubject"
    },
    "task": {
      "$ref": "#/$defs/certTask"
    },
    "producer": {
      "$ref": "#/$defs/certProducer"
    },
    "inputs": {
      "$ref": "#/$defs/certInputs"
    },
    "environment": {
      "$ref": "#/$defs/certEnvironment"
    },
    "effects": {
      "$ref": "#/$defs/certEffects"
    },
    "authority": {
      "$ref": "#/$defs/certAuthority"
    },
    "security": {
      "$ref": "#/$defs/certSecurity"
    },
    "validators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validatorResult"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "validity": {
      "$ref": "#/$defs/validity"
    },
    "provenance": {
      "$ref": "#/$defs/certProvenance"
    },
    "cache_decision": {
      "$ref": "#/$defs/certCacheDecision"
    },
    "risk_budget": {
      "$ref": "#/$defs/riskBudget"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "critical_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    },
    "extensions": {
      "type": "object"
    }
  },
  "required": [
    "schema",
    "schema_version",
    "kind",
    "certificate_id",
    "certificate_version",
    "subject",
    "task",
    "producer",
    "inputs",
    "environment",
    "effects",
    "authority",
    "security",
    "validators",
    "validity",
    "provenance",
    "cache_decision",
    "risk_budget",
    "signature"
  ],
  "additionalProperties": false,
  "$defs": {
    "gateResult": {
      "type": "object",
      "properties": {
        "gate": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "status": {
          "enum": [
            "PASS",
            "FAIL",
            "UNKNOWN"
          ]
        },
        "critical": {
          "type": "boolean"
        },
        "evidence_digest": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "gate",
        "status",
        "critical",
        "evidence_digest",
        "reason"
      ]
    },
    "certSubject": {
      "type": "object",
      "properties": {
        "artifact_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "artifact_digest"
      ]
    },
    "certTask": {
      "type": "object",
      "properties": {
        "task_spec_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "operation_key": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "realization_key": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "result_mode": {
          "enum": [
            "execution-equivalent",
            "result-satisfies",
            "evidence-only"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "task_spec_digest",
        "operation_key",
        "realization_key",
        "result_mode"
      ]
    },
    "certProducer": {
      "type": "object",
      "properties": {
        "executor_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "model_revision": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            },
            {
              "type": "null"
            }
          ]
        },
        "prompt_digest": {
          "type": "string",
          "pattern": "^hmac-sha256:[0-9a-f]{64}$"
        },
        "toolchain_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "executor_digest",
        "model_revision",
        "prompt_digest",
        "toolchain_digest"
      ]
    },
    "certInputs": {
      "type": "object",
      "properties": {
        "dependency_manifest_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "negative_dependency_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "external_inputs_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "completeness": {
          "enum": [
            "complete",
            "conservative",
            "incomplete"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "dependency_manifest_root",
        "negative_dependency_root",
        "external_inputs_root",
        "completeness"
      ]
    },
    "certEnvironment": {
      "type": "object",
      "properties": {
        "environment_contract_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "actual_environment_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "hermetic": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "environment_contract_digest",
        "actual_environment_digest",
        "hermetic"
      ]
    },
    "certEffects": {
      "type": "object",
      "properties": {
        "read_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "write_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "write_semantics": {
          "enum": [
            "none",
            "content_addressed",
            "idempotent",
            "non_idempotent"
          ]
        },
        "network_access": {
          "enum": [
            "deny",
            "pinned",
            "live"
          ]
        },
        "external_side_effects": {
          "enum": [
            "none",
            "idempotent",
            "non_idempotent"
          ]
        },
        "determinism": {
          "enum": [
            "deterministic",
            "seeded",
            "nondeterministic"
          ]
        },
        "replay_policy": {
          "enum": [
            "safe",
            "verify",
            "forbidden"
          ]
        },
        "observed_read_set_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "observed_write_set_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "network_events_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "undeclared_reads": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "undeclared_writes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "read_scope",
        "write_scope",
        "write_semantics",
        "network_access",
        "external_side_effects",
        "determinism",
        "replay_policy",
        "observed_read_set_root",
        "observed_write_set_root",
        "network_events_root",
        "undeclared_reads",
        "undeclared_writes"
      ]
    },
    "certAuthority": {
      "type": "object",
      "properties": {
        "tenant": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "project": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "classification": {
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "compartments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "capabilities_used": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "tenant",
        "project",
        "classification",
        "compartments",
        "capabilities_used"
      ]
    },
    "certSecurity": {
      "type": "object",
      "properties": {
        "taints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "allowed_consumers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "allowed_purposes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "capabilities_granted": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "taints",
        "allowed_consumers",
        "allowed_purposes",
        "capabilities_granted"
      ]
    },
    "validatorResult": {
      "type": "object",
      "properties": {
        "validator_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "predicate": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "evidence_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "unknown"
          ]
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "validator_digest",
        "predicate",
        "evidence_digest",
        "result",
        "expires_at"
      ]
    },
    "validity": {
      "type": "object",
      "properties": {
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "policy_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "invalidation_topics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "issued_at",
        "expires_at",
        "policy_digest",
        "invalidation_topics"
      ]
    },
    "certProvenance": {
      "type": "object",
      "properties": {
        "parent_certificate_digests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "uniqueItems": true
        },
        "trace_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "attempt_id": {
          "type": "string",
          "format": "uuid"
        },
        "instance_ref": {
          "$ref": "#/$defs/workflowInstanceRef"
        }
      },
      "additionalProperties": false,
      "required": [
        "parent_certificate_digests",
        "trace_id",
        "attempt_id",
        "instance_ref"
      ]
    },
    "riskBudget": {
      "type": "object",
      "properties": {
        "max_error_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_age_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "validation_wall_time_ms": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "max_error_rate",
        "max_age_seconds",
        "validation_wall_time_ms"
      ]
    },
    "certCacheDecision": {
      "type": "object",
      "properties": {
        "authorized_mode": {
          "enum": [
            "EXACT",
            "SEMANTIC",
            "ADAPT",
            "EVIDENCE_ONLY"
          ]
        },
        "gate_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gateResult"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "required": [
        "authorized_mode",
        "gate_results"
      ]
    },
    "signature": {
      "type": "object",
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "algorithm": {
          "enum": [
            "ed25519",
            "ecdsa-p256-sha256"
          ]
        },
        "signature_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "key_id",
        "algorithm",
        "signature_digest"
      ]
    },
    "templateReleaseRef": {
      "type": "object",
      "properties": {
        "logical_id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_.-]*/[A-Za-z][A-Za-z0-9_.-]*$"
        },
        "template_version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "release_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "spec_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "logical_id",
        "template_version",
        "release_digest",
        "spec_digest"
      ]
    },
    "workflowInstanceRef": {
      "type": "object",
      "properties": {
        "instance_id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "template_release": {
          "$ref": "#/$defs/templateReleaseRef"
        },
        "instance_spec_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false,
      "required": [
        "instance_id",
        "template_release",
        "instance_spec_digest"
      ]
    }
  }
}
