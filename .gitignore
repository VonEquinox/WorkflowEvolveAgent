# secrets / local env — NEVER commit
.env
*.env.local
**/.env

# deps & runtime
node_modules/
cache/

# run artifacts (traces are reproducible; keep the repo clean)
runner/runs/

# third-party reference checkout (MIT, not a runtime dep; re-checkout as needed)
pi/

# scratch
/tmp/
*.log

# python bytecode
__pycache__/
*.pyc

# stray nested run dir (path-bug guard)
runner/runner/

# champion-gate alias state (runtime, per-deployment; not source)
library/templates/*.champion.json
# exact-reuse CAS (gitignored via cache/ too, but be explicit)
library/cache/

# MCP bridge: local server config may carry secrets — keep only the example
mcp-bridge/mcp.servers.json
**/mcp.servers.json

# research / design docs — kept local, not published
research/
SELF_EVOLVING_AGENT_RESEARCH_PLAN.md
SELF_EVOLVING_AGENT_RESEARCH_PLAN_v0.2.md
PI_INTEGRATION_PLAN.md
spikes/phase0/FINDINGS.md

# offline analysis / prototypes / tests — Python, not part of the pi extension runtime
*.py
analysis/
prototypes/
tools/
tests/

# not needed to run the pi extension (IR schemas + validator samples + phase0 spike)
schemas/
examples/
spikes/
