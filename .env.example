# Copy to .env (gitignored) or export in your shell for control-assisted planning.
#
# WEA_* = CONTROL PLANE only (plan / adapt / cold-start / meta-improve).
# Worker nodes (inspect, implement, verify, …) use your default pi model
# from ~/.pi/agent/settings.json (e.g. kuaipao/grok-4.5) — not these vars.
#
# Any Anthropic-messages-compatible endpoint works for control.
# baseUrl must include the API root pi/Anthropic clients expect (often .../v1).

WEA_BASE_URL=https://your-endpoint.example/v1
WEA_API_KEY=sk-...
WEA_MODEL=your-model-id

# Optional aliases (same meaning):
# WEA_CONTROL_BASE_URL=...
# WEA_CONTROL_API_KEY=...
# WEA_CONTROL_MODEL=...

# Control transport resilience (defaults shown):
# WEA_CONTROL_TIMEOUT_MS=60000
# WEA_CONTROL_MAX_RETRIES=2

# Optional GUI port (default 7788)
# WEA_GUI_PORT=7788

# Optional interactive-Pi MCP bridge config. If omitted, the Pi package checks
# .pi/mcp.servers.json and ~/.pi/agent/mcp.servers.json, then falls back to a
# cwd-scoped workspace filesystem server.
# WEA_MCP_CONFIG=/absolute/path/to/mcp.servers.json
