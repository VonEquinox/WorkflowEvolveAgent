{
  "name": "@wea/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WEA: observable, self-evolving coding-agent workflows on the pi SDK — graph scheduler, trace/PVF export, retrieval, exact reuse, meta-improvement, champion gate",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "wea": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx src/selftest.ts",
    "smoke": "tsx src/smoke-export.ts",
    "wea": "tsx src/cli.ts",
    "run": "tsx src/cli.ts run",
    "gui": "tsx src/cli.ts gui",
    "retrieve": "tsx src/retrieval.ts",
    "improve": "tsx src/meta-improve.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
